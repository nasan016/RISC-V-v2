v0x5a2fc67aaba0_0 .net *"_ivl_2", 31 0, L_0x5a2fc67bede0;  1 drivers
v0x5a2fc67be770_0 .net "addr", 31 0, v0x5a2fc67beb60_0;  1 drivers
v0x5a2fc67be850_0 .net "instr", 31 0, L_0x5a2fc67beed0;  alias, 1 drivers
v0x5a2fc67be910 .array "rom", 2 0, 31 0;
v0x5a2fc67be9d0_0 .net "word_index", 31 2, L_0x5a2fc67becc0;  1 drivers
L_0x5a2fc67becc0 .part v0x5a2fc67beb60_0, 2, 30;
L_0x5a2fc67bede0 .array/port v0x5a2fc67be910, L_0x5a2fc67becc0;
    .scope S_0x5a2fc67aa9c0;
T_0 ;
    %pushi/vec4 286331153, 0, 32;
    %ix/load 4, 0, 0;
    %flag_set/imm 4, 0;
    %store/vec4a v0x5a2fc67be910, 4, 0;
    %pushi/vec4 572662306, 0, 32;
    %ix/load 4, 1, 0;
    %flag_set/imm 4, 0;
    %store/vec4a v0x5a2fc67be910, 4, 0;
    %pushi/vec4 858993459, 0, 32;
    %ix/load 4, 2, 0;
    %flag_set/imm 4, 0;
    %store/vec4a v0x5a2fc67be910, 4, 0;
    %end;
    .thread T_0;
    .scope S_0x5a2fc67aa830;
T_1 ;
    %pushi/vec4 0, 0, 32;
    %store/vec4 v0x5a2fc67beb60_0, 0, 32;
    %delay 1, 0;
    %load/vec4 v0x5a2fc67bec20_0;
    %cmpi/ne 286331153, 0, 32;
    %jmp/0xz  T_1.0, 6;
    %vpi_call/w 3 10 "$display", "FAIL imem[0]" {0 0 0};
    %vpi_call/w 3 10 "$finish" {0 0 0};
T_1.0 ;
    %pushi/vec4 4, 0, 32;
    %store/vec4 v0x5a2fc67beb60_0, 0, 32;
    %delay 1, 0;
    %load/vec4 v0x5a2fc67bec20_0;
